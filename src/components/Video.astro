---
import { AFFILIATE_URL } from '../consts';

interface Props {
	src: string;
	poster?: string;
	caption?: string;
	/** Aspect ratio, e.g. "16/9" or "1/1". Defaults to 16/9. */
	ratio?: string;
}

const { src, poster, caption, ratio = '16/9' } = Astro.props;
---

<figure class="my-8">
	<a href={AFFILIATE_URL} target="_blank" rel="noopener sponsored" class="block overflow-hidden rounded-2xl shadow-lg shadow-ink/5">
		<video
			src={src}
			poster={poster}
			controls
			preload="metadata"
			playsinline
			class="block w-full bg-black"
			style={`aspect-ratio: ${ratio}`}
		></video>
	</a>
	{caption && (
		<figcaption class="mt-3 text-center text-sm text-muted">{caption}</figcaption>
	)}
</figure>
