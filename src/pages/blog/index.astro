---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const [featured, ...rest] = posts;
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Blog · ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
	</head>
	<body class="bg-white text-ink-soft">
		<Header />

		<main class="mx-auto max-w-6xl px-6 py-16">
			<header class="mb-12">
				<h1 class="text-4xl font-extrabold tracking-tight text-ink md:text-5xl">The Blog</h1>
				<p class="mt-3 max-w-2xl text-muted">
					Tutorials, launches, and creative experiments — three fresh posts every day.
				</p>
			</header>

			{featured && (
				<a
					href={`/blog/${featured.id}/`}
					class="group mb-16 block overflow-hidden rounded-3xl border border-line bg-white transition hover:border-ink hover:shadow-2xl hover:shadow-ink/5 md:grid md:grid-cols-2"
				>
					{featured.data.heroImage && (
						<Image
							src={featured.data.heroImage}
							width={1200}
							height={720}
							alt={featured.data.title}
							class="aspect-[4/3] w-full object-cover md:aspect-auto md:h-full"
						/>
					)}
					<div class="flex flex-col justify-center p-8 md:p-10">
						<p class="text-xs font-semibold uppercase tracking-[0.2em] text-accent">Featured</p>
						<h2 class="mt-3 text-2xl font-bold leading-tight text-ink group-hover:text-accent md:text-3xl">
							{featured.data.title}
						</h2>
						<p class="mt-3 text-muted">{featured.data.description}</p>
						<p class="mt-4 text-xs font-medium uppercase tracking-wider text-muted">
							<FormattedDate date={featured.data.pubDate} />
						</p>
					</div>
				</a>
			)}

			{rest.length > 0 && (
				<div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
					{rest.map((post) => (
						<a
							href={`/blog/${post.id}/`}
							class="group block overflow-hidden rounded-2xl border border-line bg-white transition hover:border-ink hover:shadow-xl hover:shadow-ink/5"
						>
							{post.data.heroImage && (
								<Image
									src={post.data.heroImage}
									width={720}
									height={400}
									alt={post.data.title}
									class="aspect-[16/9] w-full object-cover"
								/>
							)}
							<div class="p-5">
								<p class="text-xs font-medium uppercase tracking-wider text-muted">
									<FormattedDate date={post.data.pubDate} />
								</p>
								<h3 class="mt-2 text-lg font-semibold leading-snug text-ink group-hover:text-accent">
									{post.data.title}
								</h3>
								<p class="mt-2 line-clamp-3 text-sm text-muted">{post.data.description}</p>
							</div>
						</a>
					))}
				</div>
			)}
		</main>

		<Footer />
	</body>
</html>
